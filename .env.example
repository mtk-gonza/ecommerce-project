ENVIRONMENT=dev
DEBUG=true
DB_TYPE=sqlite
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
SECRET_KEY=ThisIsNotSecret
ALGORITHM=HS256
UPLOADS_DIR=uploads
ACCESS_TOKEN_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_HOURS=2
API_URL=http://localhost:3050
CORS_ALLOW_ORIGINS=http://10.1.75.157:3060,http://localhost:5173
API_PORT=3050
WEB_PORT=3060
# ==================== MERCADOPAGO ====================
# Obtener credenciales en: https://www.mercadopago.com.ar/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_SANDBOX=true

# URLs para redirección (ajustar a tu dominio)
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_PENDING_URL=http://localhost:3000/payment/pending
PAYMENT_FAILURE_URL=http://localhost:3000/payment/failure

# Webhook (para recibir notificaciones de MercadoPago)
# Usar ngrok para desarrollo local: https://ngrok.com
PAYMENT_WEBHOOK_URL=https://tu-ngrok-url.ngrok.io/api/v1/payments/webhook
